/*Задача 4. Подсчёт общего размера
Реализуйте функцию, которая рекурсивно вычисляет общий размер всех файлов в 
указанном каталоге (в байтах). Размер самих каталогов не учитывайте. 
Используйте stat() или lstat() для получения размера.*/


#include <stdio.h>
#include <stdlib.h>
#include <dirent.h>
#include <string.h>
#include <sys/stat.h>

long long get_size(const char *path) {
    DIR *dir = opendir(path);
    if (!dir) return 0;
    
    struct dirent *entry;
    struct stat st;
    char fullpath[1024];
    long long total = 0;
    
    while ((entry = readdir(dir)) != NULL) {
        if (entry->d_name[0] == '.' && 
            (entry->d_name[1] == '\0' || 
             (entry->d_name[1] == '.' && entry->d_name[2] == '\0')))
            continue;
        
        snprintf(fullpath, sizeof(fullpath), "%s/%s", path, entry->d_name);
        
        if (stat(fullpath, &st) == 0) {
            if (S_ISDIR(st.st_mode))
                total += get_size(fullpath);
            else if (S_ISREG(st.st_mode))
                total += st.st_size;
        }
    }
    
    closedir(dir);
    return total;
}

int main(int argc, char *argv[]) {
    char *path = (argc == 2) ? argv[1] : ".";
    printf("%lld\n", get_size(path));
    return 0;
}
